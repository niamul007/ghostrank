# Copy this file to .env and fill in the values.
# Never commit .env to git — it contains secrets.

# Local Docker Postgres connection string.
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
# With Docker Compose running, host is "localhost" and port is 5432
# (mapped from the container by the ports: "5432:5432" setting).
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/mydb"

# Secret key used to sign JWT access tokens.
# Use a long random string in production — e.g. output of:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
ACCESS_TOKEN_SECRET=
