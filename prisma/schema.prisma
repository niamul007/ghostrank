generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  AGENCY
  ADMIN
}

enum ScanStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

model Agency {
  id          String   @id @default(cuid())
  name        String
  email       String   @unique
  password    String
  logo        String?
  brandColors Json?
  role        Role     @default(AGENCY)
  createdAt   DateTime @default(now())

  clients Client[]
}

model Client {
  id           String   @id @default(cuid())
  agencyId     String
  businessName String
  niche        String?
  location     String?
  createdAt    DateTime @default(now())

  agency  Agency   @relation(fields: [agencyId], references: [id])
  scans   Scan[]
  reports Report[]
}

model Scan {
  id          String     @id @default(cuid())
  clientId    String
  status      ScanStatus @default(PENDING)
  rawResults  Json?
  score       Float?
  promptsUsed Json?
  createdAt   DateTime   @default(now())

  client      Client       @relation(fields: [clientId], references: [id])
  scanResults ScanResult[]
  reports     Report[]
}

model ScanResult {
  id        String  @id @default(cuid())
  scanId    String
  platform  String
  prompt    String
  response  String
  mentioned Boolean @default(false)
  position  Int?
  sentiment String?

  scan Scan @relation(fields: [scanId], references: [id])
}

model Report {
  id        String   @id @default(cuid())
  scanId    String
  clientId  String
  pdfUrl    String?
  webUrl    String?
  createdAt DateTime @default(now())

  scan   Scan   @relation(fields: [scanId], references: [id])
  client Client @relation(fields: [clientId], references: [id])
}
